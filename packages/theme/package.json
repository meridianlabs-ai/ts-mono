{
  "name": "@tsmono/theme",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./base": {
      "types": "./src/base.d.ts",
      "default": "./src/base.css"
    },
    "./bootstrap-compat": {
      "types": "./src/bootstrap-compat.d.ts",
      "default": "./src/bootstrap-compat.css"
    },
    "./vscode": {
      "types": "./src/vscode.d.ts",
      "default": "./src/vscode.css"
    },
    "./apply-theme": {
      "types": "./src/apply-theme.ts",
      "default": "./src/apply-theme.ts"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@tsmono/eslint-config": "workspace:*",
    "@tsmono/tsconfig": "workspace:*",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
