{
  "name": "@tsmono/theme",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./tokens": {
      "types": "./src/tokens.d.ts",
      "default": "./src/tokens.css"
    },
    "./utilities": {
      "types": "./src/utilities.d.ts",
      "default": "./src/utilities.css"
    },
    "./reboot": {
      "types": "./src/reboot.d.ts",
      "default": "./src/reboot.css"
    },
    "./transcript": {
      "types": "./src/transcript.d.ts",
      "default": "./src/transcript.css"
    },
    "./vscode": {
      "types": "./src/vscode.d.ts",
      "default": "./src/vscode.css"
    },
    "./apply-theme": {
      "types": "./src/apply-theme.ts",
      "default": "./src/apply-theme.ts"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@tsmono/eslint-config": "workspace:*",
    "@tsmono/tsconfig": "workspace:*",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
