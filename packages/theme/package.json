{
  "name": "@tsmono/theme",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./base": {
      "types": "./src/base.d.ts",
      "default": "./src/base.css"
    },
    "./vscode": {
      "types": "./src/vscode.d.ts",
      "default": "./src/vscode.css"
    },
    "./bootstrap": {
      "types": "./src/bootstrap.ts",
      "default": "./src/bootstrap.ts"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@tsmono/eslint-config": "workspace:*",
    "@tsmono/tsconfig": "workspace:*",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^9.39.5",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
