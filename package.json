{
  "name": "tsmono",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "manypkg check && turbo run check",
    "manypkg:check": "manypkg check",
    "manypkg:fix": "manypkg fix",
    "test": "turbo run test",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "dev": "turbo run dev",
    "e2e": "turbo run e2e"
  },
  "//": "manypkg requires root deps in 'dependencies', not 'devDependencies'. The root is private and never published, so the distinction is meaningless here — it's a consistency convention.",
  "dependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@manypkg/cli": "^0.22.0",
    "@tsmono/prettier-config": "workspace:*",
    "picocolors": "^1.1.1",
    "prettier": "^3.7.4",
    "turbo": "^2.5.4"
  },
  "pnpm": {
    "overrides": {
      "yaml": "^2.4.2",
      "react-popper>react": "^19.2.0",
      "react-popper>react-dom": "^19.1.1",
      "glob": "^10.5.0",
      "js-yaml": "^4.1.0",
      "brace-expansion": "^1.1.12",
      "@isaacs/brace-expansion": "^5.0.1",
      "@codemirror/state": "^6.5.4",
      "lodash": ">=4.17.23",
      "seroval": ">=1.4.1",
      "seroval-plugins": ">=1.4.1",
      "postcss-url>minimatch": "^3.1.3",
      "@microsoft/api-extractor": "^7.57.6",
      "rollup": "^4.59.0"
    }
  },
  "manypkg": {
    "defaultBranch": "main",
    "workspaceProtocol": "require"
  }
}
