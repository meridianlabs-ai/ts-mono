{
  "name": "inspect",
  "version": "0.0.11",
  "description": "Log viewer for inspect_ai logs.",
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib",
    "lib/styles",
    "lib/assets"
  ],
  "publishConfig": {
    "name": "@meridianlabs/log-viewer"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/UKGovernmentBEIS/inspect_ai",
    "directory": "src/inspect_ai/_view/ts-mono/apps/inspect"
  },
  "scripts": {
    "build": "vite build",
    "build:lib": "vite build --mode library",
    "build:app": "vite build --mode development",
    "watch": "vite build --watch",
    "dev-watch": "NODE_ENV=development vite build --mode development --watch",
    "dev-watch-log": "cross-env DEV_LOGGING=true NODE_ENV=development vite build --mode development --watch",
    "dev": "vite",
    "dev:lib": "NODE_ENV=development vite build --mode library --watch",
    "prepublishOnly": "pnpm run build:lib",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config=jest.config.mjs",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --config=jest.config.mjs --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --config=jest.config.mjs --coverage",
    "lint": "eslint 'src/**/*.{js,jsx,mjs,ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{js,jsx,mjs,ts,tsx}' --fix",
    "tsc": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test --config playwright.config.ts",
    "check-all": "pnpm tsc && pnpm lint:fix && pnpm format && pnpm test && pnpm build"
  },
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./styles/index.css": "./lib/styles/index.css"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/plugin-transform-modules-commonjs": "^7.26.3",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-typescript": "^7.27.0",
    "@eslint/js": "^9.39.2",
    "@jest/globals": "^30.2.0",
    "@msw/playwright": "^0.4.5",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.1",
    "@tsmono/prettier-config": "workspace:*",
    "@types/bootstrap": "^5.2.10",
    "@types/clipboard": "^2.0.10",
    "@types/codemirror": "^5.60.15",
    "@types/css-modules": "^1.0.5",
    "@types/jest": "^29.5.14",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.0",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.2",
    "globals": "^15.6.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "msw": "^2.12.10",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.9.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.36.5",
    "@lezer/highlight": "^1.2.2",
    "@popperjs/core": "^2.11.8",
    "@tsmono/inspect-common": "workspace:*",
    "@tsmono/inspect-components": "workspace:*",
    "@tsmono/react": "workspace:*",
    "@tsmono/util": "workspace:*",
    "ag-grid-community": "^34.3.1",
    "ag-grid-react": "^34.3.1",
    "ansi-output": "^0.0.9",
    "asciinema-player": "^3.13.5",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "clipboard": "^2.0.11",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "dexie": "^4.3.0",
    "fast-json-patch": "^3.1.1",
    "fflate": "^0.8.2",
    "filtrex": "^3.1.0",
    "fzstd": "^0.1.1",
    "immer": "^11.1.4",
    "json5": "^2.2.3",
    "jsondiffpatch": "^0.7.3",
    "markdown-it": "^14.1.1",
    "markdown-it-mathjax3": "^5.2.0",
    "mathjax-full": "^3.2.2",
    "postcss-url": "^10.1.3",
    "prismjs": "^1.30.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-popper": "^2.3.0",
    "react-router-dom": "^7.11.0",
    "react-virtuoso": "^4.18.0",
    "zustand": "^5.0.9"
  }
}
