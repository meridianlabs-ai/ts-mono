{
  "name": "@meridianlabs/log-viewer",
  "version": "0.0.11",
  "description": "Log viewer for inspect_ai logs.",
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib",
    "lib/styles",
    "lib/assets"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UKGovernmentBEIS/inspect_ai.git",
    "directory": "src/inspect_ai/_view/ts-mono/apps/inspect"
  },
  "scripts": {
    "build": "vite build",
    "build:lib": "vite build --mode library",
    "build:app": "vite build --mode development",
    "watch": "vite build --watch",
    "dev-watch": "NODE_ENV=development vite build --mode development --watch",
    "dev-watch-log": "cross-env DEV_LOGGING=true NODE_ENV=development vite build --mode development --watch",
    "dev": "vite",
    "dev:lib": "NODE_ENV=development vite build --mode library --watch",
    "check:publishable": "node scripts/check-publishable.mjs",
    "prepublishOnly": "pnpm run check:publishable && pnpm run build:lib",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{js,jsx,mjs,ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{js,jsx,mjs,ts,tsx}' --fix",
    "tsc": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test --config playwright.config.ts",
    "check-all": "pnpm tsc && pnpm lint:fix && pnpm format && pnpm test && pnpm build"
  },
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./styles/index.css": "./lib/styles/index.css"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@msw/playwright": "^0.6.7",
    "@playwright/test": "^1.61.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.1",
    "@tsmono/eslint-config": "workspace:*",
    "@tsmono/inspect-common": "workspace:*",
    "@tsmono/inspect-components": "workspace:*",
    "@tsmono/prettier-config": "workspace:*",
    "@tsmono/react": "workspace:*",
    "@tsmono/scout-components": "workspace:*",
    "@tsmono/theme": "workspace:*",
    "@tsmono/tsconfig": "workspace:*",
    "@tsmono/util": "workspace:*",
    "@types/bootstrap": "^5.2.11",
    "@types/clipboard": "^2.0.10",
    "@types/codemirror": "^5.60.15",
    "@types/css-modules": "^1.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.2",
    "globals": "^17.6.0",
    "markdown-it-mathjax3": "^5.2.0",
    "mathjax-full": "^3.2.2",
    "msw": "^2.14.6",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.2",
    "@popperjs/core": "^2.11.8",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "@vscode-elements/react-elements": "^2.4.0",
    "@vscode/codicons": "^0.0.45",
    "ag-grid-community": "^34.3.1",
    "ag-grid-react": "^34.3.1",
    "ansi-output": "^0.0.9",
    "asciinema-player": "^3.15.1",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "clipboard": "^2.0.11",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "dexie": "^4.4.3",
    "fast-json-patch": "^3.1.1",
    "fflate": "^0.8.3",
    "filtrex": "^3.1.0",
    "fzstd": "^0.1.1",
    "immer": "^11.1.8",
    "json5": "^2.2.3",
    "jsondiffpatch": "^0.7.6",
    "markdown-it": "^14.2.0",
    "postcss-url": "^10.1.4",
    "prismjs": "^1.30.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-popper": "^2.3.0",
    "react-router-dom": "^7.17.0",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "markdown-it-mathjax3": "^5.2.0",
    "mathjax-full": "^3.2.2"
  }
}
