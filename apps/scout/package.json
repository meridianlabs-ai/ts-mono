{
  "name": "scout",
  "version": "0.0.1",
  "private": true,
  "description": "Inspect Scout viewer for evaluation logs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meridianlabs-ai/inspect_scout.git"
  },
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib",
    "lib/styles",
    "lib/assets"
  ],
  "scripts": {
    "types:generate": "node scripts/generate-types.js",
    "build": "npm run build:app",
    "build:lib": "vite build --mode library",
    "build:app": "vite build",
    "watch": "vite build --watch",
    "watch:dev": "NODE_ENV=development vite build --watch --mode development",
    "dev": "vite",
    "preview": "vite preview",
    "prepublishOnly": "pnpm run build:lib",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --config playwright.config.ts",
    "e2e:ui": "playwright test --config playwright.config.ts --ui",
    "e2e:headed": "playwright test --config playwright.config.ts --headed"
  },
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./styles/index.css": "./lib/styles/index.css"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "markdown-it-mathjax3": "^5.2.0",
    "mathjax-full": "^3.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@msw/playwright": "^0.6.7",
    "@playwright/test": "^1.61.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@testing-library/react": "^16.3.1",
    "@tsmono/eslint-config": "workspace:*",
    "@tsmono/inspect-common": "workspace:*",
    "@tsmono/inspect-components": "workspace:*",
    "@tsmono/prettier-config": "workspace:*",
    "@tsmono/react": "workspace:*",
    "@tsmono/scout-components": "workspace:*",
    "@tsmono/theme": "workspace:*",
    "@tsmono/tsconfig": "workspace:*",
    "@tsmono/util": "workspace:*",
    "@types/bootstrap": "^5.2.11",
    "@types/css-modules": "^1.0.5",
    "@types/json5": "^2.2.0",
    "@types/lodash-es": "^4.17.12",
    "@types/lz4js": "^0.2.2",
    "@types/markdown-it": "^14.1.2",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eventsource": "^4.1.0",
    "jsdom": "^29.1.1",
    "markdown-it-mathjax3": "^5.2.0",
    "mathjax-full": "^3.2.2",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typed-css-modules": "^0.9.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9",
    "zstd-codec": "^0.1.5"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev45.0",
    "@popperjs/core": "^2.11.8",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "@uwdata/flechette": "^2.5.0",
    "@vscode-elements/react-elements": "^2.4.0",
    "@vscode/codicons": "^0.0.45",
    "ag-grid-community": "^34.3.1",
    "ag-grid-react": "^34.3.1",
    "ansi-output": "^0.0.9",
    "arquero": "^8.0.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "clsx": "^2.1.1",
    "fzstd": "^0.1.1",
    "immer": "^11.1.8",
    "json5": "^2.2.3",
    "jsondiffpatch": "^0.7.6",
    "lodash-es": "^4.18.1",
    "lz4js": "^0.2.0",
    "markdown-it": "^14.2.0",
    "prismjs": "^1.30.0",
    "react-popper": "^2.3.0",
    "react-router-dom": "^7.17.0",
    "zustand": "^5.0.14"
  }
}
